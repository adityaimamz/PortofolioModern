# GITHUB VARIABLES
GITHUB_READ_USER_TOKEN_PERSONAL=

# Admin password VARIABLES - SECURITY REQUIRED
# To generate hash: node scripts/hash-password.js "your_password"
# Then copy the hash below
ADMIN_PASSWORD_HASH=$2a$12$... # Generated from hash-password.js script


# JWT_SECRET MUST be at least 32 characters and kept secret!
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_long_random_jwt_secret_key_here_minimum_32_characters

# SUPABASE VARIABLES
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# GOOGLE AI (GEMINI) VARIABLES
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy...

# PUBLIC PROFILE BRANDING (SAFE FOR CLIENT)
NEXT_PUBLIC_PROFILE_NAME=Your Name
NEXT_PUBLIC_AI_TWIN_NAME=Your AI Twin

# SERVER PROFILE BRANDING 
PUBLIC_PROFILE_NAME=Your Name
